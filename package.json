{
  "name": "quickclip",
  "version": "0.1.1",
  "description": "QuickClip - Windows clipboard manager with OCR and link previews",
  "main": "dist-main/main/main.js",
  "author": "Vexccz",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELEC -c cyan,yellow \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development tsc -p tsconfig.main.json && electron .",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run build && electron-builder --win --x64",
    "start": "electron ."
  },
  "dependencies": {
    "better-sqlite3": "11.3.0",
    "fuse.js": "7.0.0",
    "node-fetch": "2.7.0",
    "tesseract.js": "5.1.1"
  },
  "devDependencies": {
    "@electron/rebuild": "3.6.0",
    "@types/better-sqlite3": "7.6.11",
    "@types/node": "22.7.5",
    "@types/node-fetch": "2.6.11",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.3.2",
    "autoprefixer": "10.4.20",
    "concurrently": "9.0.1",
    "cross-env": "7.0.3",
    "electron": "32.2.0",
    "electron-builder": "25.1.8",
    "postcss": "8.4.47",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3",
    "vite": "5.4.10",
    "wait-on": "8.0.1"
  },
  "build": {
    "appId": "com.vexccz.quickclip",
    "productName": "QuickClip",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "dist-main/**/*",
      "dist-renderer/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "QuickClip"
    },
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/tesseract.js/**/*",
      "node_modules/tesseract.js-core/**/*"
    ]
  }
}
